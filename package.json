{
  "name": "docker-aurora-serverless",
  "version": "1.0.0",
  "description": "SQLite-backed MySQL wire protocol proxy — looks like Amazon Aurora Serverless",
  "type": "module",
  "main": "src/server.mjs",
  "scripts": {
    "start": "node src/server.mjs",
    "build:image": "docker build -t gormantec/docker-aurora-serverless:latest .",
    "build:image-force": "docker build --no-cache -t gormantec/docker-aurora-serverless:latest .",
    "push:image": "docker push gormantec/docker-aurora-serverless:latest",
    "build:push": "npm run build:image && npm run push:image",
    "test": "node --test tests/*.test.mjs"
  },
  "repository": "https://github.com/gormantec/docker-aurora-serverless",
  "keywords": ["aurora", "serverless", "mysql", "sqlite", "docker-iot", "aws-compatible"],
  "license": "MIT"
}
